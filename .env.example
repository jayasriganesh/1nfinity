# Hostinger SMTP Configuration (for Nodemailer form submissions)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=contact@infinityxglobal.com  # also used as the FROM address
SMTP_PASS=
# Cloudflare Turnstile (CAPTCHA replacement for forms)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Sheets API (form submission logging)
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEET_ID=

# Google Analytics
NEXT_PUBLIC_GA_ID=

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://infinityxglobal.com
